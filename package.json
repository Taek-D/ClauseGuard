    "react-dom": "19.2.4",
    "tailwind-merge": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "postcss": "latest",
    "tailwindcss": "4.2.1",
    "typescript": "latest"
  }
}
